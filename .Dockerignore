DS_Store
Thumbs.db

# Docker (para evitar que se copie a sí mismo)
Dockerfile
.dockerignore

# Maven wrapper (ya los copiamos explícitamente en el Dockerfile,
# pero es buena práctica evitar que se copien con el comando COPY src src)
.mvn/wrapper/*.jar